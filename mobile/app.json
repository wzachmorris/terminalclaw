{
  "expo": {
    "name": "TerminalClaw",
    "slug": "terminalclaw",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "terminalclaw",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.zacmorriss.terminalclaw",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIRequiresFullScreen": false,
        "UISupportsTrueScreenSizeOnMac": true
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d1117",
          "image": "./assets/icon.png",
          "imageWidth": 96
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
