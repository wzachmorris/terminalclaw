# Cloudflare Tunnel config — copy to ~/.cloudflared/config.yml and fill in.
#
# This tunnel is what makes the dashboard reachable at https://hub.example.com
# WITHOUT opening any inbound port on the server. cloudflared dials OUT to the
# Cloudflare edge and holds a persistent connection; Cloudflare routes requests
# for the hostname down that connection to the local `service` below.
#
# Setup (one time):
#   1. cloudflared tunnel login                       # browser auth -> writes cert.pem
#   2. cloudflared tunnel create terminalclaw              # writes <TUNNEL_ID>.json (the SECRET)
#   3. cloudflared tunnel route dns terminalclaw hub.example.com   # adds the CNAME
#   4. put this config in place, then run as a service (see below)
#
# Neither <TUNNEL_ID>.json nor cert.pem is committed — they are credentials.

tunnel: <TUNNEL_ID>                                   # uuid from `tunnel create`
credentials-file: /root/.cloudflared/<TUNNEL_ID>.json

# Public TLS terminates at the Cloudflare edge; the tunnel forwards plain HTTP
# to Caddy on a localhost-only port. Caddy does the path routing + layer-2 auth.
ingress:
  - hostname: hub.example.com
    service: http://127.0.0.1:8088
    originRequest:
      httpHostHeader: hub.example.com
  - service: http_status:404                          # catch-all

# Run it persistently with:
#   cloudflared --config ~/.cloudflared/config.yml --no-autoupdate tunnel run terminalclaw
# (install as a systemd service via `cloudflared service install`).
#
# Layer 1 auth (Cloudflare Access) is configured in the Cloudflare Zero Trust
# dashboard (Access > Applications), NOT here: add a self-hosted app for
# hub.example.com with an email/OTP allow policy.
